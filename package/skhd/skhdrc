# focus window
alt - g : yabai -m window --focus recent
alt - h : yabai -m window --focus west || ~/.config/yabai/focus_display.sh west
alt - j : yabai -m window --focus south || ~/.config/yabai/focus_display.sh south
alt - k : yabai -m window --focus north || ~/.config/yabai/focus_display.sh north
alt - l : yabai -m window --focus east || ~/.config/yabai/focus_display.sh east
# swap window
shift + alt - x : yabai -m window --swap recent
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east
# move window
shift + cmd - h : yabai -m window --warp west
shift + cmd - j : yabai -m window --warp south
shift + cmd - k : yabai -m window --warp north
shift + cmd - l : yabai -m window --warp east
# move window
shift + ctrl - a : yabai -m window --move rel:-20:0
shift + ctrl - s : yabai -m window --move rel:0:20
shift + ctrl - w : yabai -m window --move rel:0:-20
shift + ctrl - d : yabai -m window --move rel:20:0
# increase window size
shift + alt - a : yabai -m window --resize left:-20:0
shift + alt - s : yabai -m window --resize bottom:0:20
shift + alt - w : yabai -m window --resize top:0:-20
shift + alt - d : yabai -m window --resize right:20:0
# decrease window size
shift + cmd - a [
    "Google Chrome" ~
    "Slack"         ~
    "GatherV2"      ~
    *               : yabai -m window --resize left:20:0
]
shift + cmd - s : yabai -m window --resize bottom:0:-20
shift + cmd - w : yabai -m window --resize top:0:20
shift + cmd - d : yabai -m window --resize right:-20:0
# rotate tree
alt - r : yabai -m space --rotate 90
# mirror tree y-axis
alt - y : yabai -m space --mirror y-axis
# mirror tree x-axis
alt - x : yabai -m space --mirror x-axis
# toggle desktop offset
alt - a : yabai -m space --toggle padding && yabai -m space --toggle gap
# toggle window fullscreen zoom
alt - f : yabai -m window --toggle zoom-fullscreen
# toggle window native fullscreen
shift + alt - f : yabai -m window --toggle native-fullscreen
# toggle window split type
alt - e : yabai -m window --toggle split
# float / unfloat window and restore position
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2
# focus monitor - explicitly focus a standard window on the target display
# to avoid focusing non-standard windows (e.g. AquaVoice dialogs)
ctrl + alt - z  : ~/.config/yabai/focus_display.sh prev
ctrl + alt - 1  : ~/.config/yabai/focus_display.sh 1
ctrl + alt - 2  : ~/.config/yabai/focus_display.sh 2
ctrl + alt - 3  : ~/.config/yabai/focus_display.sh 3
ctrl + alt - 4  : ~/.config/yabai/focus_display.sh 4
# Move window to space and follow focus
shift + alt - 1 : yabai -m window --space 1; yabai -m space --focus 1
shift + alt - 2 : yabai -m window --space 2; yabai -m space --focus 2
shift + alt - 3 : yabai -m window --space 3; yabai -m space --focus 3
shift + alt - 4 : yabai -m window --space 4; yabai -m space --focus 4

# ── Stacking ──────────────────────────────────────────────
# toggle layout between bsp and stack
alt - s : yabai -m space --layout $(yabai -m query --spaces --space | jq -r 'if .type == "bsp" then "stack" else "bsp" end')
# cycle through stack (next / prev with wrap-around)
alt - n : yabai -m window --focus stack.next || yabai -m window --focus stack.first
alt - p : yabai -m window --focus stack.prev || yabai -m window --focus stack.last
# stack window in direction
cmd + alt - h : yabai -m window --stack west
cmd + alt - j : yabai -m window --stack south
cmd + alt - k : yabai -m window --stack north
cmd + alt - l : yabai -m window --stack east

# ── Space navigation ─────────────────────────────────────
# focus space by number
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
# focus prev/next space
alt - 0x21 : yabai -m space --focus prev
alt - 0x1E : yabai -m space --focus next

# ── Space management ─────────────────────────────────────
# create / destroy space
cmd + alt - n : yabai -m space --create
cmd + alt - d : yabai -m space --destroy
